<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="400.0" prefWidth="640.0"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="is.verkefni4expensetracker.vidmot.Controller.FlokkurController">
    <top>
        <VBox alignment="CENTER" spacing="5">
            <Label fx:id="fxNafnFlokks" text="">
                <font><Font size="24.0"/></font>
            </Label>
            <Label fx:id="fxLysing" text="" wrapText="true">
                <font><Font size="14.0"/></font>
            </Label>
        </VBox>
    </top>
    <center>
        <TableView fx:id="fxFaerslur">
            <columns>
                <TableColumn fx:id="fxLysingDalkur" text="Lýsing" prefWidth="250"/>
                <TableColumn fx:id="fxUppaedDalkur" text="Upphæð" prefWidth="150"/>
                <TableColumn fx:id="fxDagsetningDalkur" text="Dagsetning" prefWidth="150"/>
            </columns>
        </TableView>
    </center>
    <bottom>
        <HBox alignment="CENTER" spacing="20">
            <Button fx:id="fxTilBaka" onAction="#onTilBaka" text="Til baka">
                <font><Font size="16.0"/></font>
            </Button>
            <Button fx:id="fxBaetaFaerslu" onAction="#onBaetaFaerslu" text="Bæta við færslu">
                <font><Font size="16.0"/></font>
            </Button>
            <Button fx:id="fxEydaFaerslu" onAction="#onEydaFaerslu" text="Eyða færslu">
                <font><Font size="16.0"/></font>
            </Button>
        </HBox>
    </bottom>
</BorderPane>